{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Portfolio project item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "tags": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Submission": {
      "title": "Contact Submission",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User settings and metadata"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Contact form messages"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Store items"
    },
    "carts/{userId}": {
      "schema": "Cart",
      "description": "User specific carts"
    }
  }
}
