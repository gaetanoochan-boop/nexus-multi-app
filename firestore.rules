rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() { 
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is string;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'description', 'imageUrl', 'link', 'tags', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.tags is list && data.tags.size() <= 10;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 5000;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'imageUrl', 'category']) &&
             data.name is string &&
             data.price is number && data.price >= 0;
    }

    function isValidCart(data) {
      return data.keys().hasAll(['items', 'updatedAt']) &&
             data.items is list && data.items.size() <= 50;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Only allow updating certain fields or strictly validate
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role']) && 
        (incoming().role == existing().role || isAdmin()) // Only admins can change roles
      );
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isAdmin() && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow create: if isValidSubmission(incoming());
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidCart(incoming());
    }
    
    match /orders/{orderId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
